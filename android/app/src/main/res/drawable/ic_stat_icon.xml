<?xml version="1.0" encoding="utf-8"?>
<!-- Notification small icon: brain + flow wave (matches logo.svg). Must stay
     white-on-transparent — the status bar only uses the alpha channel and
     tints it with the LocalNotifications iconColor. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Brain mark (lucide "brain"), scaled up-center to leave room for the wave -->
    <group
        android:pivotX="12"
        android:pivotY="11.5"
        android:scaleX="0.72"
        android:scaleY="0.72"
        android:translateY="-2.5">
        <path
            android:pathData="M12,18V5"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M15,13a4.17,4.17 0,0 1,-3 -4,4.17 4.17,0 0,1 -3,4"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M17.598,6.5A3,3 0,1 0,12 5a3,3 0,1 0,-5.598 1.5"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M17.997,5.125a4,4 0,0 1,2.526 5.77"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M18,18a4,4 0,0 0,2 -7.464"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M19.967,17.483A4,4 0,1 1,12 18a4,4 0,1 1,-7.967 -0.517"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M6,18a4,4 0,0 1,-2 -7.464"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
        <path
            android:pathData="M6.003,5.125a4,4 0,0 0,-2.526 5.77"
            android:strokeColor="#FFFFFFFF"
            android:strokeWidth="2.2"
            android:strokeLineCap="round"
            android:strokeLineJoin="round" />
    </group>

    <!-- Flow wave accent under the brain -->
    <path
        android:pathData="M3.5,20.5C6.3,18.9 8.7,22.1 12,20.5C15.3,18.9 17.7,22.1 20.5,20.5"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
